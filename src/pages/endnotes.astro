---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { bookMeta } from "../lib/bookMeta";

const endnotes = (await getCollection("endnotes")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={`Endnotes | ${bookMeta.title}`} description="Chapter endnotes for The New Prince of Hard Times.">
  <main>
    <h1 class="page-title">Endnotes</h1>
    <p class="subtitle">Selected chapter notes for sourced examples and higher-risk factual claims. The main prose stays clean; the receipts live here and on the sources page.</p>
    <section class="source-groups">
      {endnotes.map((group) => (
        <section class="source-group" id={group.data.chapterSlug}>
          <p class="eyebrow">Chapter {group.data.chapterOrder}</p>
          <h2>{group.data.chapterTitle}</h2>
          <ol class="endnote-list">
            {group.data.notes.map((note) => (
              <li id={`note-${note.marker}`}>
                <strong>[{note.marker}]</strong> {note.text}
                {note.sources.length > 0 && (
                  <ul>
                    {note.sources.map((source) => (
                      <li><a class="text-link" href={source}>{source}</a></li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ol>
        </section>
      ))}
    </section>
  </main>
</BaseLayout>
