---
import BaseLayout from "../layouts/BaseLayout.astro";
import { bookMeta } from "../lib/bookMeta";
---

<BaseLayout title={`Copyright | ${bookMeta.title}`} description={bookMeta.copyrightNotice}>
  <main>
    <article class="reader">
      <p class="eyebrow">Copyright notice</p>
      <h1>{bookMeta.title}</h1>
      <p class="reader-subtitle">By {bookMeta.author}</p>
      <div class="reader-body">
        <p><strong>{bookMeta.copyrightNotice}</strong></p>
        <p>
          This site presents a living manuscript in draft form. Text may be revised, expanded, corrected, or removed as the work develops. No part of this manuscript may be reproduced or distributed without permission, except as permitted by law.
        </p>
        <p>
          This notice identifies the author and copyright owner for the manuscript. Formal copyright registration, if pursued, is a separate administrative step.
        </p>
        <p>
          Public evidence support for the revision edition is mapped on the <a href="/sources">sources page</a>. Internal claim notes and legal-risk comments remain repo-only while the manuscript is still being revised.
        </p>
      </div>
    </article>
  </main>
</BaseLayout>
