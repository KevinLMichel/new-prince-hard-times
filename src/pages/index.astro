---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ChapterCard from "../components/ChapterCard.astro";
import { bookMeta } from "../lib/bookMeta";

const chapters = (await getCollection("chapters")).sort((a, b) => a.data.order - b.data.order);
const appendices = (await getCollection("appendices")).sort((a, b) => a.data.order - b.data.order);
const draftCount = chapters.filter((chapter) => chapter.data.status === "draft").length;
const outlineCount = chapters.filter((chapter) => chapter.data.status === "outline").length;
const revisionCount = chapters.filter((chapter) => ["revision", "polished"].includes(chapter.data.status)).length;
---

<BaseLayout
  title={bookMeta.title}
  description={bookMeta.description}
>
  <main>
    <section class="hero">
      <div>
        <p class="eyebrow">A living field guide</p>
        <h1>The New Prince of Hard Times</h1>
        <p class="byline">By {bookMeta.author}</p>
        <p class="subtitle">
          {bookMeta.subtitle}
        </p>
        <p class="hero-actions">
          <a class="button-link" href="/chapters">Enter the manuscript</a>
          <a class="button-link" href="/appendices">Use the appendices</a>
          <a class="button-link" href={bookMeta.pdfPath} download>{bookMeta.downloadLabel}</a>
        </p>
      </div>
      <aside class="panel" aria-label="Book premise">
        <p class="manifesto-line">Everything may not be fine. Therefore become stronger, clearer, and more useful.</p>
        <p>
          This site is the working draft: chapter by chapter, pass by pass, with status markers left visible so the book can grow without pretending to be finished.
        </p>
        <p>
          The downloadable PDF is a quiet revision edition for full-book reading, formatted as a 5.5 by 8.5 inch trade-book snapshot.
        </p>
      </aside>
    </section>

    <section class="grid" aria-label="Core promises">
      <div class="panel">
        <p class="eyebrow">Premise</p>
        <p>A good society cannot be built by frightened people who do not understand power.</p>
      </div>
      <div class="panel">
        <p class="eyebrow">Method</p>
        <p>Name the machinery, refuse despair, and turn crisis literacy into household and civic discipline.</p>
      </div>
      <div class="panel">
        <p class="eyebrow">Progress</p>
        <p>{chapters.length} chapters and {appendices.length} field tools. {draftCount} drafts, {outlineCount} outlines, {revisionCount} revised or polished.</p>
      </div>
    </section>

    <section class="progress-panel" aria-label="Manuscript progress">
      <div>
        <span>{chapters.length}</span>
        <small>Total chapters</small>
      </div>
      <div>
        <span>{appendices.length}</span>
        <small>Appendices</small>
      </div>
      <div>
        <span>{draftCount}</span>
        <small>Drafts</small>
      </div>
      <div>
        <span>{outlineCount}</span>
        <small>Outlines</small>
      </div>
      <div>
        <span>{revisionCount}</span>
        <small>Revised / polished</small>
      </div>
    </section>

    <section class="section-heading">
      <h2>Current Chapters</h2>
      <a class="text-link" href="/chapters">Full table of contents</a>
    </section>

    <section class="grid">
      {chapters.map((chapter) => <ChapterCard chapter={chapter} />)}
    </section>
  </main>
</BaseLayout>
