---
interface Props {
  to: string;
  label: string;
}

const { to, label } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <link rel="canonical" href={to} />
    <title>Redirecting | The New Prince of Hard Times</title>
  </head>
  <body>
    <p>
      This chapter moved to <a href={to}>{label}</a>.
    </p>
    <script is:inline>
      window.location.replace(document.querySelector("a").href);
    </script>
  </body>
</html>
