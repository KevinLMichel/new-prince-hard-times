---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { bookMeta } from "../../lib/bookMeta";

export async function getStaticPaths() {
  const chapters = (await getCollection("chapters")).sort((a, b) => a.data.order - b.data.order);
  return chapters.map((chapter, index) => ({
    params: { slug: chapter.id.replace(/\.md$/, "") },
    props: {
      chapter,
      previousChapter: chapters[index - 1] ?? null,
      nextChapter: chapters[index + 1] ?? null,
      minutes: Math.max(1, Math.ceil((chapter.body ?? "").split(/\s+/).filter(Boolean).length / 225))
    }
  }));
}

const { chapter, previousChapter, nextChapter, minutes } = Astro.props;
const { Content } = await render(chapter);
const currentChapterSlug = (entry: { id: string }) => entry.id.replace(/\.md$/, "");
---

<BaseLayout title={`${chapter.data.title} | ${bookMeta.title}`} description={chapter.data.summary}>
  <main>
    <article class="reader">
      <div class="reader-meta">
        <span>Chapter {chapter.data.order.toString().padStart(2, "0")}</span>
        <span>{chapter.data.part}</span>
        <span class={`status status--${chapter.data.status}`}>{chapter.data.status}</span>
        <span>Updated {chapter.data.updated.toLocaleDateString("en-US")}</span>
        <span>{minutes} min read</span>
      </div>
      <h1>{chapter.data.title}</h1>
      <p class="byline">By {bookMeta.author}</p>
      {chapter.data.subtitle && <p class="reader-subtitle">{chapter.data.subtitle}</p>}
      {chapter.data.dek && <p class="reader-dek">{chapter.data.dek}</p>}
      <div class="reader-body">
        <Content />
      </div>
      <nav class="chapter-nav" aria-label="Chapter navigation">
        <a class="button-link" href="/chapters">Back to chapters</a>
        <div>
          {previousChapter && <a class="text-link" href={`/chapters/${currentChapterSlug(previousChapter)}`}>Previous: {previousChapter.data.title}</a>}
          {nextChapter && <a class="text-link" href={`/chapters/${currentChapterSlug(nextChapter)}`}>Next: {nextChapter.data.title}</a>}
        </div>
      </nav>
    </article>
  </main>
</BaseLayout>
