---
import "../styles/global.css";
import { bookMeta } from "../lib/bookMeta";

interface Props {
  title: string;
  description?: string;
}

const { title, description = `A living manuscript for ${bookMeta.title}.` } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-mark">NP</span>
          <span>
            <strong>The New Prince</strong>
            <small>of Hard Times</small>
            <small>by {bookMeta.author}</small>
          </span>
        </a>
        <nav aria-label="Primary navigation">
          <a href="/">Home</a>
          <a href="/chapters">Chapters</a>
          <a href="/about">About</a>
          <a href={bookMeta.pdfPath} download>Download PDF</a>
        </nav>
      </header>
      <slot />
      <footer class="site-footer">
        <div>
          <p>{bookMeta.copyrightNotice}</p>
          <p>Living manuscript. Drafted in the open, revised with receipts.</p>
        </div>
        <div class="footer-links">
          <a class="text-link" href={bookMeta.pdfPath} download>Download PDF</a>
          <a class="text-link" href="/sources">Sources</a>
          <a class="text-link" href="/copyright">Copyright</a>
        </div>
      </footer>
    </div>
  </body>
</html>
