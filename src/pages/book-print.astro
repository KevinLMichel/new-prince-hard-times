---
import { getCollection, render } from "astro:content";
import PrintChapter from "../components/PrintChapter.astro";
import PrintAppendix from "../components/PrintAppendix.astro";
import { bookMeta } from "../lib/bookMeta";
import { sourceGroups } from "../lib/sourceGroups";

const chapters = (await getCollection("chapters")).sort((a, b) => a.data.order - b.data.order);
const appendices = (await getCollection("appendices")).sort((a, b) => a.data.order - b.data.order);
const endnotes = (await getCollection("endnotes")).sort((a, b) => a.data.order - b.data.order);

const renderedChapters = await Promise.all(
  chapters.map(async (chapter) => {
    const { Content } = await render(chapter);
    return {
      chapter,
      Content,
      slug: chapter.id.replace(/\.md$/, "")
    };
  })
);

const renderedAppendices = await Promise.all(
  appendices.map(async (appendix) => {
    const { Content } = await render(appendix);
    return {
      appendix,
      Content,
      slug: appendix.id.replace(/\.md$/, "")
    };
  })
);

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="author" content={bookMeta.author} />
    <meta name="description" content={`Print/PDF edition of ${bookMeta.title} by ${bookMeta.author}.`} />
    <title>{bookMeta.title} | PDF Edition</title>
  </head>
  <body>
    <section class="title-page" aria-label="Title page">
      <div>
        <p class="title-eyebrow">A field guide for hard times</p>
        <h1>{bookMeta.title}</h1>
        <p class="title-subtitle">{bookMeta.subtitle}</p>
        <p class="title-author">Kevin L. Michel</p>
      </div>
    </section>

    <section class="copyright-page" aria-label="Copyright page">
      <p><strong>{bookMeta.title}</strong></p>
      <p>Copyright © 2026 Kevin L. Michel.</p>
      <p>All rights reserved.</p>
      <p>
        No part of this publication may be reproduced, distributed, transmitted, stored in a retrieval system, or used in any form or by any means, electronic, mechanical, photocopying, recording, or otherwise, without prior written permission from the copyright owner, except as permitted by law.
      </p>
      <p>
        This book is provided for informational and educational purposes only. It does not constitute legal, financial, tax, medical, investment, employment, or other professional advice. Readers should consult qualified professionals for advice regarding their own circumstances.
      </p>
      <p>
        References to public figures, companies, institutions, government offices, products, services, and events are used for commentary, criticism, education, and discussion. All trademarks and trade names are the property of their respective owners.
      </p>
      <p>Printed in the United States of America.</p>
    </section>

    <nav class="toc-page" aria-label="Table of contents">
      <h1>Contents</h1>
      <ol>
        {
          renderedChapters.map(({ chapter, slug }) => (
            <li>
              <div class="toc-entry" data-target={`#${slug}`}>
                <span class="toc-chapter">Chapter {chapter.data.order}</span>
                <span class="toc-title">{chapter.data.title}</span>
              </div>
            </li>
          ))
        }
        <li>
          <div class="toc-entry" data-target="#appendices">
            <span class="toc-chapter">Tools</span>
            <span class="toc-title">Appendices and Worksheets</span>
          </div>
        </li>
        <li>
          <div class="toc-entry" data-target="#endnotes">
            <span class="toc-chapter">Notes</span>
            <span class="toc-title">Endnotes</span>
          </div>
        </li>
        <li>
          <div class="toc-entry" data-target="#bibliography">
            <span class="toc-chapter">Sources</span>
            <span class="toc-title">Source Bibliography</span>
          </div>
        </li>
      </ol>
    </nav>

    <main class="book-body">
      {
        renderedChapters.map(({ chapter, slug, Content }) => (
          <PrintChapter chapter={chapter} slug={slug} Content={Content} />
        ))
      }

      <section class="book-section-opener" id="appendices">
        <p class="chapter-kicker">Field tools</p>
        <h1>Appendices and Worksheets</h1>
        <p>Use these pages as working tools. They are not decorations for the argument; they are how the argument becomes practice.</p>
      </section>

      {
        renderedAppendices.map(({ appendix, slug, Content }) => (
          <PrintAppendix appendix={appendix} slug={slug} Content={Content} />
        ))
      }

      <section class="book-section-opener endnotes-section" id="endnotes">
        <p class="chapter-kicker">Receipts</p>
        <h1>Endnotes</h1>
        <p>Selected notes for sourced examples and higher-risk factual claims.</p>
        {
          endnotes.map((group) => (
            <section class="print-endnote-group">
              <h2>Chapter {group.data.chapterOrder}: {group.data.chapterTitle}</h2>
              <ol>
                {group.data.notes.map((note) => (
                  <li>
                    <strong>[{note.marker}]</strong> {note.text}
                    {note.sources.length > 0 && (
                      <ul>
                        {note.sources.map((source) => <li>{source}</li>)}
                      </ul>
                    )}
                  </li>
                ))}
              </ol>
            </section>
          ))
        }
      </section>

      <section class="book-section-opener bibliography-section" id="bibliography">
        <p class="chapter-kicker">Sources</p>
        <h1>Source Bibliography</h1>
        <p>Plain-text source map for the current revision. The website sources page keeps clickable links for reader convenience.</p>
        {
          sourceGroups.map((group) => (
            <section class="print-endnote-group">
              <h2>{group.heading}</h2>
              <p>{group.description}</p>
              <ul>
                {group.sources.map((source) => (
                  <li>
                    <strong>{source.publisher}: {source.title}.</strong> {source.use} Source: {source.url}
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </section>
    </main>
  </body>
</html>
