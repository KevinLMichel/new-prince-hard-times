---
const { chapter, slug, Content } = Astro.props;
---

<article class="book-chapter" id={slug}>
  <header class="chapter-opener">
    <p class="chapter-kicker">Chapter {chapter.data.order}</p>
    <h1>{chapter.data.title}</h1>
    {chapter.data.subtitle && <p class="chapter-subtitle">{chapter.data.subtitle}</p>}
  </header>
  <div class="chapter-body">
    <Content />
  </div>
</article>
